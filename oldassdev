#!/bin/sh
set -eu

case "${1:-}" in
  featurealign|feature-align|feature-alignment)
    echo "Use oldassdev featurealign on this ticket."
    ;;
  plan|featureplan|feature-plan)
    echo "Use oldassdev featureplan for the approved work."
    ;;
  change|ponytail|ponytail-change)
    echo "Use oldassdev change for the smallest useful change."
    ;;
  qa|qagate|qa-gate)
    echo "Use oldassdev qa before merge."
    ;;
  review|reviewpr|review-pr)
    echo "Use oldassdev review before merge."
    ;;
  "")
    echo "Usage: oldassdev featurealign"
    ;;
  *)
    echo "Unknown step: $1" >&2
    echo "Try: featurealign, featureplan, change, qa, review" >&2
    exit 1
    ;;
esac
