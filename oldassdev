#!/bin/sh
set -eu

case "${1:-}" in
  featurealign|feature-align|feature-alignment)
    echo "Use feature-alignment on this ticket."
    ;;
  plan|featureplan|feature-plan)
    echo "Use feature-plan for the approved work."
    ;;
  change|ponytail|ponytail-change)
    echo "Use ponytail-change for the smallest useful change."
    ;;
  qa|qagate|qa-gate)
    echo "Use qa-gate before merge."
    ;;
  review|reviewpr|review-pr)
    echo "Use review-pr before merge."
    ;;
  "")
    echo "Usage: oldassdev featurealign"
    ;;
  *)
    echo "Unknown step: $1" >&2
    echo "Try: featurealign, plan, change, qa, review" >&2
    exit 1
    ;;
esac
